{
  "experiment_name": "exp1_quick_15m",
  "seed": 42,
  "output_dir": "results/exp1_quick_15m",
  "model": {
    "attn_type": "baseline",
    "task_dim": 20,
    "max_context": 40,
    "d_model": 128,
    "n_layers": 2,
    "n_heads": 4,
    "d_mlp": 256,
    "dropout": 0.0
  },
  "data": {
    "noise_std": 0.0,
    "x_distribution": "isotropic",
    "skew_power": 2.0,
    "orthant_mode": "none"
  },
  "train": {
    "batch_size": 64,
    "total_steps": 1800,
    "learning_rate": 0.001,
    "weight_decay": 0.01,
    "warmup_steps": 200,
    "grad_clip": 1.0,
    "loss_mode": "sequence",
    "log_interval": 100,
    "eval_interval": 1000,
    "checkpoint_interval": 1000,
    "resume": false,
    "curriculum": {
      "enabled": true,
      "start_dim": 5,
      "end_dim": 20,
      "end_step": 600,
      "start_context": 5,
      "end_context": 40,
      "context_end_step": 600
    }
  },
  "eval": {
    "num_prompts": 256,
    "batch_size": 128,
    "gd_eta": 1.0,
    "knn_k": 3,
    "ridge_lambda": 0.01,
    "compute_baselines": true,
    "compute_alignment": true
  }
}
