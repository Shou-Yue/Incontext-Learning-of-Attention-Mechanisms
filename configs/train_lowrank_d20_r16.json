{
  "experiment_name": "lowrank_d20_r16",
  "seed": 42,
  "output_dir": "results/train_lowrank_d20_r16",
  "model": {
    "attn_type": "lowrank",
    "attn_rank": 16,
    "task_dim": 20,
    "max_context": 40,
    "d_model": 256,
    "n_layers": 4,
    "n_heads": 8,
    "d_mlp": 1024,
    "dropout": 0.0
  },
  "train": {
    "batch_size": 64,
    "total_steps": 100000,
    "learning_rate": 0.001,
    "weight_decay": 0.01,
    "warmup_steps": 5000,
    "grad_clip": 1.0,
    "log_interval": 100,
    "eval_interval": 1000,
    "checkpoint_interval": 5000,
    "resume": true,
    "curriculum": {
      "enabled": true,
      "start_dim": 5,
      "end_dim": 20,
      "end_step": 20000,
      "start_context": 5,
      "end_context": 40,
      "context_end_step": 20000
    }
  }
}
